<% content_for(:title, t('.title')) %>
<div class="w-full max-w-[1200px] mx-auto px-4 sm:px-6 md:px-8 my-8 sm:my-12 md:my-20">
  <div class="w-full text-black">
    <div class="text-center space-y-4 sm:space-y-6 md:space-y-8">
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-heading font-bold"><%= t('.title') %></h2>
      <p class="text-sm sm:text-base md:text-lg font-body"><%= t('.description') %></p>
    </div>
    <div class="w-full mt-8">
      <% if @answer == "111" %>
        <%= render 'geisya' %>
      <% elsif @answer == "110" %>
        <%= render 'mocha' %>
      <% elsif @answer == "101" %>
        <%= render 'blue_mountain' %>
      <% elsif @answer == "100" %>
        <%= render 'cuba_crystal_mountain' %>
      <% elsif @answer == "011" %>
        <%= render 'guatemala' %>
      <% elsif @answer == "010" %>
        <%= render 'colombia_emerald_mountain' %>
      <% elsif @answer == "001" %>
        <%= render 'mandheling' %>
      <% elsif @answer == "000" %>
        <%= render 'vietnam' %>
      <% else %>
        <h3 class="text-center text-3xl font-heading">
          無効な回答です。<br>
          再度、診断をお願いいたします。
        </h3>
      <% end %>
    </div>
    <div class="flex flex-col items-center w-full mt-8 space-y-6">
      <%= link_to t('.to_diagnosis_page'), new_diagnosis_path, class: "btn btn-warning w-full sm:w-[200px] h-[50px] mx-auto" %>
      <%= link_to t('.to_bean_index'), beans_path, class: "btn btn-primary w-full sm:w-[200px] h-[50px] mx-auto" %>
    </div>
  </div>
</div>
