<% content_for(:title, t('.title')) %>
<div class="flex flex-col items-center w-full max-w-[1000px] mx-auto px-4 sm:px-6 py-8">
  <div class="w-full text-black">
    <div class="text-center font-bold">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading"><%= t('.title') %></h2>
    </div>

    <div class="mt-6 md:mt-8">
      <!-- 投稿フォームのパーシャルを表示 -->
      <%= render 'form', bean: @bean %>
    </div>

    <!-- 豆詳細へ戻るボタン -->
    <div class="text-center font-body w-full mt-6 md:mt-10">
      <%= link_to t('.back_to_show_bean'), bean_path(@bean), class: "btn btn-accent w-full sm:w-[200px] h-[50px] mx-auto" %>
    </div>
  </div>
</div>
