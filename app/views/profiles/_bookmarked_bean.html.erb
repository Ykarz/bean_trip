<div class="card bg-white w-full h-auto sm:h-[450px] border-[2px] border-primary rounded-lg font-body overflow-hidden">
  <!-- 投稿画像を表示する部分 -->
  <figure>
    <%= image_tag bookmarked_bean.image_url(:image_on_card), class: "w-full h-40 sm:h-56 object-cover" %>
  </figure>

  <!-- 投稿内容を表示する部分 -->
  <div class="card-body text-black shadow-md p-4 sm:p-6">
    <!-- 銘柄を詳細ページへのリンクにする -->
    <%= link_to bean_path(bookmarked_bean), data: { turbo: false } do %>
      <h4 class="card-title truncate text-sm sm:text-base font-bold underline mb-2 sm:mb-3">
        <%= bookmarked_bean.name %>
      </h4>
    <% end %>
    <div class="space-y-[6px] text-left text-sm">
      <p class="truncate">
        <%= Country.human_attribute_name(:name) %>：<%= bookmarked_bean.country.name %>
      </p>
      <p class="truncate">
        <%= Bean.human_attribute_name(:roast_level) %>：<%= bookmarked_bean.roast_level_i18n %>
      </p>
      <p class="line-clamp-2 text-sm"><%= bookmarked_bean.comment %></p>
    </div>

    <div class="flex flex-row justify-between items-center mt-4">
      <!-- 投稿ユーザー情報表示エリア -->
      <div class="flex flex-row items-center space-x-3">
        <!-- 投稿ユーザーのアバター画像を表示 -->
        <div class="flex items-center justify-center">
          <%= image_tag bookmarked_bean.user.avatar_url, class: "rounded-full object-cover w-8 h-8 md:w-10 md:h-10" %>
        </div>
        <div class="flex flex-col justify-center text-xs space-y-1">
          <p class="truncate text-sm"><%= bookmarked_bean.user.name %></p>
          <p class="truncate text-sm"><%= bookmarked_bean.created_at.strftime("%Y/%m/%d") %></p>
        </div>
      </div>

      <!-- 編集・削除アイコン表示エリア -->
      <!-- ログインユーザーのidと投稿コンテンツのユーザーidが等しければ表示 -->
      <% if user_signed_in? %>
        <% if current_user.own?(bookmarked_bean) %>
          <div class="flex flex-row items-center space-x-4 text-lg sm:text-xl">
            <%= link_to edit_bean_path(bookmarked_bean), id: "button-edit-#{bookmarked_bean.id}", data: { turbo: false } do %>
              <i class="fa-solid fa-pen-to-square"></i>
            <% end %>
            <%= link_to bean_path(bookmarked_bean), id: "button-delete-#{bookmarked_bean.id}", data: { turbo_method: :delete, turbo_confirm: t('defaults.delete_confirm') } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          </div>
        <!-- ログインユーザーが作成した投稿でない場合は、ブックマークボタンを表示 -->
        <% else %>
          <div class="flex flex-row text-accent text-lg sm:text-xl">
            <%= render 'beans/bookmark_buttons', bean: bookmarked_bean %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
