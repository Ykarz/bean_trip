<% content_for(:title, t('.title')) %>
<!-- プロフィール編集ページ：ユーザー情報（ユーザー名、メールアドレス、アバター画像）を編集することができる -->
<div class="flex flex-col items-center mx-auto w-full max-w-[700px] px-4 sm:px-6 md:px-8">
  <h2 class="text-center text-2xl sm:text-3xl lg:text-4xl font-bold font-heading my-8 sm:my-10 lg:my-[40px]"><%= t('.title') %></h2>

  <!-- アバター画像のプレビュー -->
  <div class="mx-auto my-6 sm:my-8">
    <%= image_tag @user.avatar_url, class: "rounded-full object-cover w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28" %>
  </div>

  <!-- プロフィール編集フォーム -->
  <%= form_with model: @user, url: profile_path, method: :put, local: true, html: { class: "w-full" } do |f| %>
    <!-- エラーメッセージのパーシャル -->
    <%= render "shared/error_messages", object: f.object %>

    <!-- ユーザー名の入力欄 -->
    <div class="form-control text-left font-body my-6 sm:my-8">
      <%= f.label :name, class: "label w-full font-bold" %>
      <%= f.text_field :name, autofocus: true, class: "input input-bordered input-primary w-full h-11 sm:h-12 bg-white border-[3px] border-primary rounded-md", placeholder: t('.placeholder.name') %>
    </div>

    <!-- メールアドレスの入力欄 -->
    <div class="form-control text-left font-body mb-6 sm:mb-8">
      <%= f.label :email, class: "label w-full font-bold" %>
      <%= f.email_field :email, autofocus: true, class: "input input-bordered input-primary w-full h-11 sm:h-12 bg-white border-[3px] border-primary rounded-md", placeholder: t('.placeholder.email') %>
    </div>

    <!-- アバター画像のアップロード欄 -->
    <div class="form-control text-left font-body mb-6 sm:mb-8">
      <%= f.label :avatar, t('.label.avatar'), class: "label w-full font-bold" %>
      <%= f.file_field :avatar, class: "file-input file-input-bordered file-input-primary w-full h-11 sm:h-12 bg-white border-[3px] border-primary rounded-md" %>
      <%= f.hidden_field :avatar_cache %>
    </div>

    <!-- 更新ボタン -->
    <div class="text-center mt-6 sm:mt-8 mb-8 sm:mb-12">
      <%= f.submit t('.update_profile'), class: "btn btn-accent w-full sm:w-[200px] h-11 sm:h-12", data: { action: "click->loading#show" } %>
    </div>
  <% end %>

  <!-- プロフィール閲覧ページへ戻るボタン -->
  <div class="text-center mb-8 sm:mb-[100px] w-full sm:w-auto">
    <%= link_to t('.back_to_profile_page'), profile_path, data: { turbo: false }, class: "btn btn-primary w-full sm:w-[200px] h-11 sm:h-12" %>
  </div>
</div>
