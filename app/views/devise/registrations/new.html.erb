<div class="mx-auto my-24 px-4 w-full max-w-[700px] flex flex-col items-center">
  <div class="w-full text-black">
    <div class="text-center font-bold space-y-2">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading"><%= t('devise.registrations.new.title') %></h2>
      <p class="text-sm md:text-base font-body">～ 投稿やブックマークが可能になります ～</p>
    </div>

    <%= form_with model: @user, url: user_registration_path, local: true do |f|  %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="field text-left text-sm md:text-base font-body mt-8 md:mt-12 mb-8 md:mb-10 space-y-2">
        <%= f.label :name, class: "w-full font-bold" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.registrations.new.account_validate') %>
      </div>

      <div class="field text-left text-sm md:text-base font-body mb-8 md:mb-10 space-y-2">
        <%= f.label :email, class: "w-full font-bold" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.registrations.new.input_email') %>
      </div>

      <div class="field text-left text-sm md:text-base font-body mb-8 md:mb-10 space-y-2">
        <%= f.label :password, class: "w-full font-bold" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.registrations.new.minimum_password_length', password_length: @minimum_password_length) %>
      </div>

      <div class="field text-left text-sm md:text-base font-body mb-10 md:mb-12 space-y-2">
        <%= f.label :password_confirmation, class: "w-full font-bold" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.registrations.new.re_input_password') %>
      </div>

      <div class="actions text-center w-full mb-10 md:mb-12">
        <%= f.submit t('devise.registrations.new.create'), class: "btn btn-primary w-full md:w-[200px] h-12 md:h-[50px] px-4", data: { action: "click->loading#show" } %>
      </div>
    <% end %>
  </div>

  <%= render "devise/shared/links" %>
</div>
