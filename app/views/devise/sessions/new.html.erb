<div class="mx-auto my-24 px-4 w-full max-w-[700px] flex flex-col items-center">
  <div class="w-full text-black">
    <div class="text-center mb-6 md:mb-8">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold font-heading"><%= t('devise.sessions.new.title') %></h2>
    </div>

    <%= form_with model: @user, url: user_session_path, local: true do |f| %>
      <div class="field text-left text-sm md:text-base font-body mb-8 md:mb-10 space-y-2">
        <%= f.label :email, class: "w-full font-bold" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.sessions.new.input_email') %>
      </div>

      <div class="field text-left text-sm md:text-base font-body mb-8 md:mb-10 space-y-2">
        <%= f.label :password, class: "w-full font-bold" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered input-primary form-control w-full h-12 md:h-[50px] bg-white border-[3px] border-primary rounded-lg px-3", placeholder: t('devise.sessions.new.input_password') %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center justify-center w-full mb-8 md:mb-10">
          <%= f.check_box :remember_me, class: "checkbox checkbox-primary border-[2px] mr-2 md:mr-3" %>
          <%= f.label :remember_me, class: "cursor-pointer font-body" %>
        </div>
      <% end %>

      <div class="actions text-center w-full mb-8 md:mb-10">
        <%= f.submit t('devise.sessions.new.sign_in'), class: "btn btn-primary w-full md:w-[200px] h-12 md:h-[50px] px-4", data: { action: "click->loading#show" } %>
      </div>
    <% end %>
  </div>

  <div class="text-center font-body font-bold underline mt-4 md:mt-6">
    <%= link_to t('devise.shared.links.sign_up'), new_user_registration_path %><br />
  </div>
</div>
