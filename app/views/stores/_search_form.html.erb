<!-- Ransackを使用した検索フォーム（レスポンシブ対応） -->
<%= search_form_for q, url: url do |f| %>
  <div class="flex flex-col md:flex-row justify-center items-center space-y-2 md:space-y-0 md:space-x-4 w-full my-5 px-4">
    <!-- 店舗名と住所に対する検索フィールド（曖昧検索） -->
    <div class="form-control w-full">
      <%= f.search_field :name_or_address_cont, class: "input input-bordered input-primary bg-white w-full md:w-auto border-[3px] border-primary rounded-lg", placeholder: t('stores.search_form.placeholder.name_address') %>
    </div>

    <div class="w-full md:w-auto">
      <%= f.submit t('defaults.search'), class: "btn btn-accent w-full md:w-[100px]", data: { action: "click->loading#show" } %>
    </div>
  </div>
<% end %>
