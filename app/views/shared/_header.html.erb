<header>
  <div class="navbar bg-primary text-base-100 px-6 py-2 md:py-4 z-45">
    <!-- 左側：ロゴとタイトル -->
    <div class="navbar-start">
      <%= link_to root_path, class: "flex items-center space-x-2" do %>
        <i class="fa-solid fa-mug-saucer text-2xl md:text-4xl"></i>
        <span class="text-2xl md:text-4xl font-heading font-bold"><%= t('header.title') %></span>
      <% end %>
    </div>

    <!-- 右側：デバイスに関係なくドロップダウンメニューを表示 -->
    <div class="navbar-end">
      <div class="dropdown dropdown-bottom dropdown-end">
        <!-- ドロップダウンのトリガー（ハンバーガーメニューアイコン） -->
        <label tabindex="0" class="btn btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content menu bg-primary rounded-box z-50 w-56 text-base-100 font-bold p-2 shadow">
          <li><%= link_to t('header.to_diagnosis_page'), new_diagnosis_path %></li>
          <li><%= link_to t('header.to_bean_index'), beans_path %></li>
          <li><%= link_to t('header.to_store_index'), stores_path %></li>
          <% if user_signed_in? %>
            <li><%= link_to t('header.to_profile_page'), profile_path %></li>
            <li><%= link_to t('header.logout'), destroy_user_session_path, data: { turbo_method: :delete } %></li>
          <% else %>
            <li><%= link_to t('header.to_new_registration_page'), new_user_registration_path %></li>
            <li><%= link_to t('header.to_new_session_page'), new_user_session_path %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</header>
